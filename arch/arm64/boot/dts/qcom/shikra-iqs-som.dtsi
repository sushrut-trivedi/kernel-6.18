&thermal_zones {
	sys-1-thermal {
		thermal-sensors = <&pm8150_adc_tm 0>;

		trips {
			active-config0 {
				temperature = <125000>;
				hysteresis = <1000>;
				type = "passive";
			};
		};
	};

	sys-2-thermal {
		thermal-sensors = <&pm8150_adc_tm 1>;

		trips {
			active-config0 {
				temperature = <125000>;
				hysteresis = <1000>;
				type = "passive";
			};
		};
	};

	sys-3-thermal {
		thermal-sensors = <&pm8150_adc_tm 2>;

		trips {
			active-config0 {
				temperature = <125000>;
				hysteresis = <1000>;
				type = "passive";
			};
		};
	};
};
