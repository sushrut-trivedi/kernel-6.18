		};

		pm8150_l8: l8 {
			regulator-min-microvolt = <1150000>;
			regulator-max-microvolt = <1304000>;
		};

		pm8150_l9: l9 {
			regulator-min-microvolt = <875000>;
			regulator-max-microvolt = <1000000>;
		};

		pm8150_l10:l10{
			regulator-min-microvolt = <2700000>;
